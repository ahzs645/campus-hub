{
  "name": "campus-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run build:docs",
    "build:app": "next build",
    "build:docs": "cd docs && npm run build && cp -r dist ../out/docs",
    "dev:docs": "cd docs && npm run dev",
    "start": "next start",
    "lint": "eslint",
    "android-mobile-build": "cd ../campus-hub-app/android && ./gradlew app:assembleDebug",
    "android-mobile": "cd ../campus-hub-app/android && ./gradlew app:installDebug && adb shell am start -n com.campushub.mobile/.MainActivity"
  },
  "dependencies": {
    "@campus-hub/configurator": "file:../campus-hub-configurator",
    "@campus-hub/engine": "file:../campus-hub-engine",
    "@firstform/json-url": "^4.1.0",
    "gridstack": "^12.4.2",
    "gtfs-realtime-bindings": "^1.1.1",
    "lottie-web": "^5.13.0",
    "lucide-react": "^0.542.0",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-pixel-display": "^1.0.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  }
}
