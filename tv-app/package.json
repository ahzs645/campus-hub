{
  "name": "campus-hub-tv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android-tv-build": "cd android && ./gradlew app:assembleDebug",
    "android-tv": "cd android && ./gradlew app:installDebug && adb shell am start -n com.campushubtv/.MainActivity",
    "tvos": "react-native run-ios --scheme CampusHubTV --simulator 'Apple TV'",
    "start": "react-native start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@react-native-community/netinfo": "^12.0.1",
    "react": "19.2.3",
    "react-native": "npm:react-native-tvos@0.84.1-0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-svg": "^15.11.2",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-webview": "^13.16.1"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.0",
    "@react-native-community/cli-platform-android": "^20.1.0",
    "@react-native-community/cli-platform-ios": "^20.1.0",
    "@react-native-community/cli-server-api": "^20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/react": "^19.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
