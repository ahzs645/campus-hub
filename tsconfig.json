{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@firstform/campus-hub-engine": ["./packages/campus-hub-engine/src/index.ts"],
      "@firstform/campus-hub-engine/widgets": ["./packages/campus-hub-engine/src/widgets/index.ts"],
      "@firstform/campus-hub-engine/src/*": ["./packages/campus-hub-engine/src/*"],
      "@firstform/campus-hub-configurator": ["./packages/campus-hub-configurator/src/index.ts"],
      "@firstform/campus-hub-widget-sdk": ["./packages/campus-hub-widget-sdk/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/campus-hub-widgets/packages/*/src/**/*.ts",
    "packages/campus-hub-widgets/packages/*/src/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "docs", "tv-app", "packages/*/node_modules"]
}
