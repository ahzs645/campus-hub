<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000114"
    tools:context=".MainActivity">

    <!-- Pairing Screen (shown when no display is linked) -->
    <ScrollView
        android:id="@+id/pairingScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/pair_title"
                android:textColor="#B7C0C8"
                android:textSize="16sp"
                android:gravity="center" />

            <!-- QR Code for cloud pairing -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_qr_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/pairQrCode"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:background="#FFFFFF"
                    android:contentDescription="@string/pair_qr_description"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/pair_qr_caption"
                    android:textColor="#B7C0C8"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Pairing code display -->
            <TextView
                android:id="@+id/pairCodeDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_panel"
                android:fontFamily="monospace"
                android:paddingStart="32dp"
                android:paddingTop="16dp"
                android:paddingEnd="32dp"
                android:paddingBottom="16dp"
                android:textColor="#F6D67A"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                tools:text="482 159" />

            <TextView
                android:id="@+id/pairCodeInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="#D3D9DF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/pairStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="#FF6B6B"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:background="#22FFFFFF" />

            <!-- Manual display ID entry -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/manual_entry_label"
                android:textColor="#B7C0C8"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/manualDisplayIdInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="@string/manual_entry_hint"
                android:inputType="text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#667788"
                android:textSize="16sp" />

            <Button
                android:id="@+id/manualPairButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_primary"
                android:text="@string/manual_pair_button"
                android:textAllCaps="false"
                android:textColor="#081018"
                android:textSize="16sp" />

            <!-- Scan TV QR code button -->
            <Button
                android:id="@+id/scanTvQrButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/scan_tv_qr_button"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>

    <!-- Paired Screen (shown when display is linked) -->
    <LinearLayout
        android:id="@+id/pairedScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/paired_title"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pairedDisplayName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#F6D67A"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pairedDisplayId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#667788"
            android:textSize="14sp"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/openDisplayButton"
            android:layout_width="280dp"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/open_display"
            android:textAllCaps="false"
            android:textColor="#081018"
            android:textSize="16sp" />

        <Button
            android:id="@+id/openDashboardButton"
            android:layout_width="280dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:text="@string/open_dashboard"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/unpairButton"
            android:layout_width="280dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:text="@string/unpair"
            android:textAllCaps="false"
            android:textColor="#FF6B6B"
            android:textSize="16sp" />
    </LinearLayout>
</FrameLayout>
